# Vimeo API credentials
VIMEO_ACCESS_TOKEN=your_vimeo_access_token
VIMEO_USER_ID=123456789
VIMEO_FOLDER_ID=1234567

# Timezone and weekday mapping
TIMEZONE_NAME=Europe/London
WEEKDAY_MAP={"Mon":0,"Tue":1,"Wed":2,"Thu":3,"Fri":4,"Sat":5,"Sun":6}

# Courses to sync (format: SUBJECT-GRADE-WEEKDAY-HHMM)
COURSES=["SUBJECT-G7-Mon-0810","SUBJECT-G8-Thu-1200"]
# Regex pattern to parse course names — named groups must match COURSE_TITLE_PATTERN_GROUP_MAP
COURSE_TITLE_PATTERN=^(?P<course_type>[^-]+)-(?P<grade_group>[^-]+)-(?P<weekday>Mon|Tue|Wed|Thu|Fri|Sat|Sun)-(?P<start_time>\d{4})$
COURSE_TITLE_PATTERN_GROUP_MAP={"course_type":"course_type","weekday":"weekday","start_time":"start_time","grade_group":"grade_group"}
COURSE_TITLE_TIME_FORMATS=["%H%M"]

# Keywords used to match Vimeo recording titles to course subjects
RECORDING_TYPE_KEYWORDS={"SUBJECT":["subject","subj"]}
# Regex to extract date and time from Vimeo recording titles
RECORDING_TITLE_TIMESTAMP_PATTERN=.*?(?P<date>\d{4}-\d{2}-\d{2})\s+(?P<time>\d{2}:\d{2}(?::\d{2})?)$
# Whether the timestamp in recording titles is in UTC or local time (utc or local)
RECORDING_TITLE_TIMESTAMP_TIMEZONE=utc
RECORDING_TITLE_TIMESTAMP_DATETIME_FORMATS=["%Y-%m-%d %H:%M:%S","%Y-%m-%d %H:%M"]
# How many minutes before/after scheduled start time a recording can still be matched
RECORDING_EARLY_TOLERANCE_MINUTES=30
RECORDING_LATE_TOLERANCE_MINUTES=60

# Paths to resource files (absolute or relative to working directory)
VIDEO_SETTINGS_FILE=resources/video_settings.json
VIDEO_SETTINGS_NAME_FIELD=name
VIDEO_NAME_TIMESTAMP_FORMAT=%Y%m%d
VIDEO_EMBED_TEMPLATE_FILE=resources/video_embed_template.html
VIDEO_EMBED_CONFIGURATION={"max_width":"800","width":"100","height":"540"}

# Moodle API credentials and section date format
MOODLE_BASE_URL=https://your-moodle-instance.example.com
MOODLE_ACCESS_TOKEN=your_moodle_access_token
# Template for matching course section titles to dates (e.g. "5. March")
MOODLE_SECTION_DATE_TEMPLATE={day}. {month_name}
# Localised month names used in section titles
MOODLE_SECTION_MONTH_ALIASES={"1":"January","2":"February","3":"March","4":"April","5":"May","6":"June","7":"July","8":"August","9":"September","10":"October","11":"November","12":"December"}
